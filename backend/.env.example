LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# Timeouts (seconds) — increase connect if you see ConnectTimeout on slow networks/VPN
LLM_CONNECT_TIMEOUT=45
LLM_READ_TIMEOUT=180
# Monte Carlo projection horizons (comma-separated days) and confidence decay
PROJECTION_HORIZONS_DAYS=30,90,180,365
PROJECTION_CONFIDENCE_TAU=90
MONTE_CARLO_SIMULATIONS=10000

# Instagram (fixes 403 Forbidden on GraphQL — required for real profile scraping)
# Step 1: run once:  instaloader --login=YOUR_IG_USERNAME
# Step 2: set your IG username below (session file is auto-loaded from ~/.config/instaloader/)
INSTAGRAM_USERNAME=your_ig_username
# Optional: full path if session is not in the default location
# INSTAGRAM_SESSION=/Users/you/.config/instaloader/session-your_ig_username
INSTAGRAM_SESSION=

# Enrichment limits (rate-limit safe defaults)
INSTAGRAM_ENRICH_POSTS=10
INSTAGRAM_MAX_COMMENTS_PER_POST=30
INSTAGRAM_MAX_LIKERS_PER_POST=24
INSTAGRAM_FEED_PAGE_SIZE=50
INSTAGRAM_MAX_FEED_PAGES=120
# Full-archive fetch (fetch_all_posts=true): max pages per source (feed + clips)
INSTAGRAM_MAX_FEED_PAGES_ALL=500
